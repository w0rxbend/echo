{
  "openapi": "3.0.3",
  "info": {
    "title": "LED Matrix Proxy",
    "description": "HTTP proxy for ESP8266 LED matrix controllers. Events are normalized, matched through rules, and scheduled serially to the matrix TCP connection.\n\nAll device-specific endpoints use `/api/v1/devices/{device}/` where `{device}` is a configured device ID. Global endpoints (`/api/v1/animations`, `/api/v1/animations/catalog`) are device-independent.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:8080" }
  ],
  "tags": [
    { "name": "health", "description": "Liveness and readiness" },
    { "name": "events", "description": "Event ingress" },
    { "name": "animations", "description": "Animation discovery (global)" },
    { "name": "device", "description": "Device-specific playback and controls (requires device ID)" }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "tags": ["health"],
        "summary": "Liveness probe",
        "description": "Always returns 200 while the process is running.",
        "responses": {
          "200": { "description": "Process alive", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StatusOK" } } } }
        }
      }
    },
    "/readyz": {
      "get": {
        "tags": ["health"],
        "summary": "Readiness probe",
        "description": "Returns 200 when workers are running and all configured devices are connected. Returns 503 otherwise. The `devices` object shows per-device breakdown.",
        "responses": {
          "200": { "description": "Ready", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReadyResponse" } } } },
          "503": { "description": "Not ready", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReadyResponse" } } } }
        }
      }
    },
    "/metrics": {
      "get": {
        "tags": ["health"],
        "summary": "Prometheus metrics",
        "description": "Per-device metrics carry a `device` label. Event-bus metrics are global.",
        "responses": {
          "200": { "description": "Prometheus text exposition format", "content": { "text/plain": {} } }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "tags": ["health"],
        "summary": "This OpenAPI spec",
        "responses": {
          "200": { "description": "OpenAPI 3.0 JSON", "content": { "application/json": {} } }
        }
      }
    },
    "/api/v1/animations": {
      "get": {
        "tags": ["animations"],
        "summary": "List playable animation IDs",
        "description": "Returns only generated/renderable animations. Firmware preset IDs (not directly playable) are excluded.",
        "responses": {
          "200": {
            "description": "Animation list",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AnimationList" } } }
          }
        }
      }
    },
    "/api/v1/animations/catalog": {
      "get": {
        "tags": ["animations"],
        "summary": "Full animation catalog",
        "description": "Returns all registered animations including firmware presets. Each entry exposes `id`, `kind`, and `playable`. Firmware presets have `playable: false` and may include `effect_id`, `interval`, and `color`.",
        "responses": {
          "200": {
            "description": "Animation catalog",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AnimationCatalog" } } }
          }
        }
      }
    },
    "/api/v1/devices": {
      "get": {
        "tags": ["device"],
        "summary": "List device IDs",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Device list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DeviceList" } } } }
        }
      }
    },
    "/api/v1/devices/{device}/events": {
      "post": {
        "tags": ["events"],
        "summary": "Publish a generic event",
        "description": "Publishes a normalized event for async rule processing. Known override attributes (`animation`, `restore`, `duration`, `interrupt_mode`) are validated before publishing.",
        "parameters": [{ "$ref": "#/components/parameters/device" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EventRequest" } } }
        },
        "responses": {
          "202": { "description": "Accepted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EventAccepted" } } } },
          "400": { "description": "Validation error" },
          "404": { "description": "Unknown device" },
          "503": { "description": "Event bus backpressure timeout" }
        }
      }
    },
    "/api/v1/devices/{device}/notify": {
      "post": {
        "tags": ["events"],
        "summary": "Send a notification",
        "description": "Publishes an event with `source: http` and `type: notify`. Triggers rules matching that source/type.",
        "parameters": [{ "$ref": "#/components/parameters/device" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NotifyRequest" } } }
        },
        "responses": {
          "202": { "description": "Accepted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EventAccepted" } } } },
          "400": { "description": "Validation error" },
          "404": { "description": "Unknown device" },
          "503": { "description": "Event bus backpressure timeout" }
        }
      }
    },
    "/api/v1/devices/{device}/play": {
      "post": {
        "tags": ["device"],
        "summary": "Enqueue an animation",
        "description": "Directly enqueues a renderable animation on the device scheduler. Admin endpoint.",
        "parameters": [{ "$ref": "#/components/parameters/device" }],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PlayRequest" } } }
        },
        "responses": {
          "202": { "description": "Accepted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RequestAccepted" } } } },
          "400": { "description": "Unknown or non-playable animation, or invalid parameters" },
          "401": { "description": "Missing bearer token" },
          "403": { "description": "Invalid bearer token" },
          "404": { "description": "Unknown device" }
        }
      }
    },
    "/api/v1/devices/{device}/queue": {
      "get": {
        "tags": ["device"],
        "summary": "Inspect the play queue",
        "parameters": [{ "$ref": "#/components/parameters/device" }],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Queue snapshot", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/QueueResponse" } } } }
        }
      },
      "delete": {
        "tags": ["device"],
        "summary": "Clear the play queue",
        "parameters": [{ "$ref": "#/components/parameters/device" }],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Items cleared", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/QueueClearResponse" } } } }
        }
      }
    },
    "/api/v1/devices/{device}/background": {
      "get": {
        "tags": ["device"],
        "summary": "Get idle background configuration",
        "description": "Returns the current desired idle animation for this device. When `restore_on_idle` is true, the scheduler converges the display back to this animation whenever the play queue empties.",
        "parameters": [{ "$ref": "#/components/parameters/device" }],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Current background config",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BackgroundConfigBody" } } }
          }
        }
      },
      "put": {
        "tags": ["device"],
        "summary": "Set idle background animation at runtime",
        "description": "Replaces the device's desired idle background. The scheduler will start converging to the new animation at the next idle opportunity. Set `restore_on_idle: false` or omit `animation` to disable idle convergence.",
        "parameters": [{ "$ref": "#/components/parameters/device" }],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BackgroundConfigBody" } } }
        },
        "responses": {
          "200": { "description": "Background updated", "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string" }, "animation": { "type": "string" } } } } } },
          "400": { "description": "Unknown animation ID or validation error" },
          "401": { "description": "Missing bearer token" },
          "403": { "description": "Invalid bearer token" },
          "404": { "description": "Unknown device" }
        }
      }
    },
    "/api/v1/devices/{device}/matrix/clear": {
      "post": {
        "tags": ["device"],
        "summary": "Clear the display",
        "parameters": [{ "$ref": "#/components/parameters/device" }],
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": {
          "200": { "description": "OK" },
          "502": { "description": "Matrix firmware error" },
          "503": { "description": "Scheduler stopped or control canceled" }
        }
      }
    },
    "/api/v1/devices/{device}/matrix/brightness": {
      "post": {
        "tags": ["device"],
        "summary": "Set display brightness",
        "parameters": [{ "$ref": "#/components/parameters/device" }],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BrightnessRequest" } } }
        },
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Invalid value" },
          "502": { "description": "Matrix firmware error" }
        }
      }
    },
    "/api/v1/devices/{device}/matrix/preset": {
      "post": {
        "tags": ["device"],
        "summary": "Apply a firmware effect preset",
        "parameters": [{ "$ref": "#/components/parameters/device" }],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PresetRequest" } } }
        },
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Invalid interval or effect_id" },
          "502": { "description": "Matrix firmware error" }
        }
      }
    },
    "/api/v1/devices/{device}/matrix/fill": {
      "post": {
        "tags": ["device"],
        "summary": "Fill display with a solid colour",
        "parameters": [{ "$ref": "#/components/parameters/device" }],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ColorRequest" } } }
        },
        "responses": {
          "200": { "description": "OK" },
          "502": { "description": "Matrix firmware error" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Required when server.addr is not a loopback address. Token value from the env var named by server.admin_token_env."
      }
    },
    "parameters": {
      "device": {
        "name": "device",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Device ID as configured in the `devices:` map (e.g. `living-room`)."
      }
    },
    "schemas": {
      "StatusOK": {
        "type": "object",
        "properties": { "status": { "type": "string", "example": "ok" } }
      },
      "ReadyResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["ready", "not_ready"] },
          "workers_running": { "type": "boolean" },
          "draining": { "type": "boolean" },
          "event_worker": {
            "type": "object",
            "properties": {
              "state": { "type": "string", "enum": ["idle", "processing"] },
              "stage": { "type": "string" },
              "active_duration_seconds": { "type": "number" }
            }
          },
          "devices": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "scheduler_state": { "type": "string", "enum": ["disconnected", "connecting", "ready", "playing_transient", "restoring_background", "draining"] },
                "matrix_connected": { "type": "boolean" },
                "background": { "$ref": "#/components/schemas/BackgroundReady" },
                "last_success": { "type": "string", "format": "date-time" },
                "last_failure": { "type": "string", "format": "date-time" }
              }
            }
          }
        }
      },
      "BackgroundReady": {
        "type": "object",
        "properties": {
          "configured_id": { "type": "string" },
          "kind": { "type": "string", "enum": ["firmware_preset", "generated"] },
          "state": { "type": "string", "enum": ["unknown", "dirty", "attempting", "converged", "failed", "retrying"] },
          "dirty": { "type": "boolean" },
          "converged": { "type": "boolean" },
          "last_attempt": { "type": "string", "format": "date-time" },
          "last_success": { "type": "string", "format": "date-time" },
          "next_retry": { "type": "string", "format": "date-time" },
          "failure_count": { "type": "integer" },
          "last_error": { "type": "string" },
          "last_error_class": { "type": "string", "enum": ["none", "retryable", "permanent"] }
        }
      },
      "DeviceList": {
        "type": "object",
        "properties": {
          "devices": { "type": "array", "items": { "type": "string" } }
        }
      },
      "AnimationList": {
        "type": "object",
        "properties": {
          "animations": { "type": "array", "items": { "type": "string" } }
        }
      },
      "AnimationCatalog": {
        "type": "object",
        "properties": {
          "animations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "kind", "playable"],
              "properties": {
                "id": { "type": "string" },
                "kind": { "type": "string", "enum": ["generated", "firmware_preset"] },
                "playable": { "type": "boolean" },
                "effect_id": { "type": "integer" },
                "interval": { "type": "string", "example": "90ms" },
                "color": { "$ref": "#/components/schemas/Color" }
              }
            }
          }
        }
      },
      "EventRequest": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string" },
          "type": { "type": "string" },
          "text": { "type": "string" },
          "priority": { "type": "integer" },
          "attributes": { "type": "object", "additionalProperties": { "type": "string" } }
        }
      },
      "NotifyRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "message": { "type": "string" },
          "level": { "type": "string" },
          "animation": { "type": "string", "description": "Override the matched rule's animation ID." },
          "duration": { "type": "string", "example": "2s" },
          "priority": { "type": "integer" },
          "restore": { "type": "string", "enum": ["background", "leave", "clear", "blank", "previous_frame"] },
          "params": { "type": "object", "additionalProperties": { "type": "string" } }
        }
      },
      "PlayRequest": {
        "type": "object",
        "required": ["animation"],
        "properties": {
          "animation": { "type": "string" },
          "duration": { "type": "string", "example": "2s" },
          "priority": { "type": "integer" },
          "restore": { "type": "string", "enum": ["background", "leave", "clear", "blank", "previous_frame"] },
          "interrupt_mode": { "type": "string", "enum": ["none", "higher_priority", "critical"] },
          "params": { "type": "object", "additionalProperties": { "type": "string" } }
        }
      },
      "BrightnessRequest": {
        "type": "object",
        "required": ["value"],
        "properties": { "value": { "type": "integer", "minimum": 0, "maximum": 255 } }
      },
      "PresetRequest": {
        "type": "object",
        "properties": {
          "effect_id": { "type": "integer", "minimum": 0, "maximum": 255 },
          "interval": { "type": "string", "example": "90ms" },
          "color": { "$ref": "#/components/schemas/Color" }
        }
      },
      "ColorRequest": { "$ref": "#/components/schemas/Color" },
      "Color": {
        "type": "object",
        "properties": {
          "r": { "type": "integer", "minimum": 0, "maximum": 255 },
          "g": { "type": "integer", "minimum": 0, "maximum": 255 },
          "b": { "type": "integer", "minimum": 0, "maximum": 255 }
        }
      },
      "EventAccepted": {
        "type": "object",
        "properties": { "event_id": { "type": "string" } }
      },
      "RequestAccepted": {
        "type": "object",
        "properties": { "request_id": { "type": "string" } }
      },
      "QueueResponse": {
        "type": "object",
        "properties": {
          "depth": { "type": "integer" },
          "state": { "type": "string" },
          "items": { "type": "array", "items": { "type": "object" } }
        }
      },
      "QueueClearResponse": {
        "type": "object",
        "properties": { "cleared": { "type": "integer" } }
      },
      "BackgroundConfigBody": {
        "type": "object",
        "properties": {
          "animation": {
            "type": "string",
            "description": "Animation ID to use as idle background. Must exist in the animation registry. Both renderable animations and firmware presets are valid."
          },
          "restore_on_idle": {
            "type": "boolean",
            "description": "When true and animation is non-empty, the scheduler will converge the display to this animation whenever idle. Set false to stop idle convergence."
          }
        }
      }
    }
  }
}
