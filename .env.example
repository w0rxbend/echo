# Required: admin token for protected endpoints (play, queue, matrix controls)
# Required when server.addr is not a loopback address (always needed for Docker)
MATRIX_PROXY_ADMIN_TOKEN=changeme-use-a-strong-secret

# Optional overrides
PROXY_PORT=8080
LOG_LEVEL=info

# Optional observability stack password (default: admin)
GRAFANA_PASSWORD=admin
